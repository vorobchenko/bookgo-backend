# Server
PORT=8080
NODE_ENV=development

# PostgreSQL (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgresql://user:password@host:5432/bookgo
# Set to true for Railway / cloud Postgres with SSL
DATABASE_SSL=true

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d

# Seed admin (run once: npm run seed:admin)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-8chars
SEED_ADMIN_NAME=Admin
SEED_ADMIN_LANG=en
