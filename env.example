# Server
PORT=8080
NODE_ENV=development

# Supabase Postgres — Dashboard → Project Settings → Database → Connection string
# Use "Session pooler" (port 5432) for Express + transactions.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# Optional alias (same value as DATABASE_URL)
# SUPABASE_DB_URL=

# SSL: auto-enabled for *.supabase.com URLs; set explicitly if needed
DATABASE_SSL=true
# DATABASE_POOL_MAX=10

# Supabase project
SUPABASE_URL=https://byttvudgaibixzarzeol.supabase.co
SUPABASE_PROJECT_REF=byttvudgaibixzarzeol

# Supabase Storage (S3-compatible) — Dashboard → Storage → S3 Connection
SUPABASE_S3_ENDPOINT=https://byttvudgaibixzarzeol.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=eu-west-1
SUPABASE_STORAGE_BUCKET=files
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d

# Anthropic — AI theme style generation (POST /pages/:id/theme/ai-style)
ANTHROPIC_API_KEY=
# Optional model override (default: claude-opus-4-6)
# ANTHROPIC_MODEL=claude-opus-4-6
# Faster/cheaper alternative: claude-sonnet-4-6
# Max logo-to-theme batches per page per hour (default: 10)
# AI_STYLE_RATE_LIMIT_PER_HOUR=10

# Seed admin (run once: npm run seed:admin)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-8chars
SEED_ADMIN_NAME=Admin
SEED_ADMIN_LANG=en
