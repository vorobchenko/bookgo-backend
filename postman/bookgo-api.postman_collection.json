                  "pm.test('user email', () => pm.expect(json.data.user.email).to.be.a('string'));"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "PATCH /profile/edit",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{acceptLanguage}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin\",\n  \"city\": \"Warsaw\",\n  \"timezone\": \"Europe/Warsaw\",\n  \"lang\": \"ru\"\n}"
            },
            "url": "{{baseUrl}}/profile/edit"
          },
          "response": []
        },
        {
          "name": "PUT /profile/change-password",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{acceptLanguage}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"new_password\": \"new-password-8chars\",\n  \"password_confirm\": \"new-password-8chars\"\n}"
            },
            "url": "{{baseUrl}}/profile/change-password"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Pages",
      "description": "CRUD страницы, publish/unpublish, set-default. Услуги и аватар — в отдельных папках.",
      "item": [
        {
          "name": "GET /pages",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept-Language", "value": "{{acceptLanguage}}" }],
            "url": "{{baseUrl}}/pages"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('pages array', () => pm.expect(json.data.pages).to.be.an('array'));",
                  "if (json.data.pages.length > 0) {",
                  "  pm.collectionVariables.set('pageId', json.data.pages[0].id);",
                  "  pm.collectionVariables.set('pageSlug', json.data.pages[0].slug);",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "POST /pages",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{acceptLanguage}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"slug\": \"demo-coaching-{{$timestamp}}\"\n}"
            },
            "url": "{{baseUrl}}/pages"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.test('page id', () => pm.expect(json.data.page.id).to.be.a('string'));",
                  "pm.test('starter service', () => pm.expect(json.data.page.settings.services.services.length).to.be.above(0));",
                  "if (json.data?.page) {",
                  "  pm.collectionVariables.set('pageId', json.data.page.id);",
                  "  pm.collectionVariables.set('pageSlug', json.data.page.slug);",
                  "  const first = json.data.page.settings?.services?.services?.[0];",
                  "  if (first?.id) pm.collectionVariables.set('serviceId', first.id);",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "GET /pages/:id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept-Language", "value": "{{acceptLanguage}}" }],
            "url": "{{baseUrl}}/pages/{{pageId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('profile in settings', () => pm.expect(json.data.page.settings.profile).to.be.an('object'));",
                  "pm.test('blocks array', () => pm.expect(json.data.page.settings.blocks).to.be.an('array'));",
                  "const first = json.data.page.settings?.services?.services?.[0];",
                  "if (first?.id) pm.collectionVariables.set('serviceId', first.id);"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "PATCH /pages/:id",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{acceptLanguage}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"settings\": {\n    \"profile\": {\n      \"name\": \"Max Volkov\",\n      \"role\": \"Strength Coach\",\n      \"bio\": \"Certified coach.\",\n      \"city\": \"Warsaw\",\n      \"lang\": \"en\",\n      \"avatar_url\": \"\",\n      \"email\": \"coach@example.com\",\n      \"phone\": \"+48123456789\"\n    },\n    \"availability\": {\n      \"timezone\": \"Europe/Warsaw\",\n      \"buffer_after_minutes\": 15,\n      \"min_notice_hours\": 4,\n      \"max_days_ahead\": 60,\n      \"slot_interval_minutes\": 15,\n      \"max_bookings_per_day\": 0,\n      \"days\": [\n        {\n          \"weekday\": 1,\n          \"working\": true,\n          \"ranges\": [{ \"id\": \"rng-1\", \"start\": \"09:00\", \"end\": \"17:00\" }]\n        },\n        {\n          \"weekday\": 2,\n          \"working\": true,\n          \"ranges\": [{ \"id\": \"rng-2\", \"start\": \"09:00\", \"end\": \"17:00\" }]\n        },\n        {\n          \"weekday\": 3,\n          \"working\": true,\n          \"ranges\": [{ \"id\": \"rng-3\", \"start\": \"09:00\", \"end\": \"17:00\" }]\n        },\n        {\n          \"weekday\": 4,\n          \"working\": true,\n          \"ranges\": [{ \"id\": \"rng-4\", \"start\": \"09:00\", \"end\": \"17:00\" }]\n        },\n        {\n          \"weekday\": 5,\n          \"working\": true,\n          \"ranges\": [{ \"id\": \"rng-5\", \"start\": \"09:00\", \"end\": \"17:00\" }]\n        }\n      ]\n    }\n  }\n}"
            },
            "url": "{{baseUrl}}/pages/{{pageId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('updated profile name', () => pm.expect(json.data.page.settings.profile.name).to.eql('Max Volkov'));"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "POST /pages/:id/publish",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept-Language", "value": "{{acceptLanguage}}" }],
            "url": "{{baseUrl}}/pages/{{pageId}}/publish"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (pm.response.code === 200) {",
                  "  pm.test('published', () => pm.expect(json.data.page.published).to.eql(true));",
                  "} else if (pm.response.code === 400) {",
                  "  pm.test('validation errors', () => pm.expect(json.data.validation.errors).to.be.an('array'));",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "POST /pages/:id/unpublish",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept-Language", "value": "{{acceptLanguage}}" }],
            "url": "{{baseUrl}}/pages/{{pageId}}/unpublish"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('unpublished', () => pm.expect(json.data.page.published).to.eql(false));"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "POST /pages/:id/set-default",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept-Language", "value": "{{acceptLanguage}}" }],
            "url": "{{baseUrl}}/pages/{{pageId}}/set-default"
          },
          "response": []
        },
        {
          "name": "DELETE /pages/:id",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept-Language", "value": "{{acceptLanguage}}" }],
            "url": "{{baseUrl}}/pages/{{pageId}}"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Page Avatar",
      "description": "Фото профиля витрины. Контракт: docs/pages_avatar_api.md",
      "item": [
        {
          "name": "POST /pages/:id/avatar",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept-Language", "value": "{{acceptLanguage}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "avatar",
                  "description": "JPEG, PNG, WebP or GIF, max 5 MB",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": "{{baseUrl}}/pages/{{pageId}}/avatar"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('avatar_url returned', () => pm.expect(json.data.avatar_url).to.be.a('string').and.not.empty);",
                  "pm.test('profile avatar_url set', () => pm.expect(json.data.page.settings.profile.avatar_url).to.eql(json.data.avatar_url));"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "DELETE /pages/:id/avatar",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept-Language", "value": "{{acceptLanguage}}" }],
            "url": "{{baseUrl}}/pages/{{pageId}}/avatar"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('avatar_url cleared', () => pm.expect(json.data.page.settings.profile.avatar_url).to.eql(''));"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Page Availability",
      "description": "Schedule: weekly hours, booking rules. Контракт: docs/pages_availability_api.md",
      "item": [
        {
          "name": "GET /pages/:id/availability",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept-Language", "value": "{{acceptLanguage}}" }],
            "url": "{{baseUrl}}/pages/{{pageId}}/availability"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('availability block', () => pm.expect(json.data.availability.days).to.have.lengthOf(7));",
                  "pm.test('meta', () => pm.expect(json.data.meta.has_working_hours).to.be.a('boolean'));"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "PATCH /pages/:id/availability/weekly-hours",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{acceptLanguage}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"timezone\": \"Europe/Warsaw\",\n  \"days\": [\n    {\n      \"weekday\": 1,\n      \"working\": true,\n      \"ranges\": [{ \"id\": \"rng-1\", \"start\": \"09:00\", \"end\": \"17:00\" }]\n    },\n    {\n      \"weekday\": 2,\n      \"working\": true,\n      \"ranges\": [{ \"id\": \"rng-2\", \"start\": \"09:00\", \"end\": \"17:00\" }]\n    },\n    {\n      \"weekday\": 3,\n      \"working\": true,\n      \"ranges\": [{ \"id\": \"rng-3\", \"start\": \"09:00\", \"end\": \"17:00\" }]\n    },\n    {\n      \"weekday\": 4,\n      \"working\": true,\n      \"ranges\": [{ \"id\": \"rng-4\", \"start\": \"09:00\", \"end\": \"17:00\" }]\n    },\n    {\n      \"weekday\": 5,\n      \"working\": true,\n      \"ranges\": [{ \"id\": \"rng-5\", \"start\": \"09:00\", \"end\": \"17:00\" }]\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/pages/{{pageId}}/availability/weekly-hours"
          },
          "response": []
        },
        {
          "name": "PATCH /pages/:id/availability/booking-rules",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{acceptLanguage}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"buffer_after_minutes\": 15,\n  \"slot_interval_minutes\": 15,\n  \"min_notice_hours\": 4,\n  \"max_days_ahead\": 60,\n  \"max_bookings_per_day\": 0\n}"
            },
            "url": "{{baseUrl}}/pages/{{pageId}}/availability/booking-rules"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Page Theme",
      "description": "Theme: accent, fonts, element style, background. Контракт: docs/pages_theme_api.md",
      "item": [
        {
          "name": "GET /pages/:id/theme",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept-Language", "value": "{{acceptLanguage}}" }],
            "url": "{{baseUrl}}/pages/{{pageId}}/theme"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('theme block', () => {",
                  "  pm.expect(json.data.theme.accent_color).to.match(/^#[0-9A-Fa-f]{6}$/);",
                  "  pm.expect(json.data.theme.font_preset).to.be.a('string');",
                  "  pm.expect(json.data.theme.secondary_color).to.match(/^#[0-9A-Fa-f]{6}$/);",
                  "  pm.expect(json.data.theme.cta.variant).to.be.oneOf(['solid', 'outline', 'ghost']);",
                  "  pm.expect(json.data.theme.atmosphere.card_style).to.be.oneOf(['solid', 'glass']);",
                  "  pm.expect(json.data.theme.background.type).to.be.oneOf(['solid', 'gradient', 'image']);",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "PATCH /pages/:id/theme",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept-Language", "value": "{{acceptLanguage}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"secondary_color\": \"#f472b6\",\n  \"cta\": { \"variant\": \"outline\", \"size\": \"large\" },\n  \"atmosphere\": { \"card_style\": \"glass\" },\n  \"background\": {\n    \"type\": \"gradient\",\n    \"gradient_from\": \"#0a0a0a\",\n    \"gradient_to\": \"#1a1a2e\",\n    \"gradient_angle\": 180,\n    \"overlay_opacity\": 0.2\n  }\n}"
            },
            "url": "{{baseUrl}}/pages/{{pageId}}/theme"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('theme updated', () => {",
                  "  pm.expect(json.data.theme.cta.variant).to.eql('outline');",
                  "  pm.expect(json.data.theme.atmosphere.card_style).to.eql('glass');",
                  "  pm.expect(json.data.theme.background.type).to.eql('gradient');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Page Slots",
      "description": "Computed booking slots. Контракт: docs/pages_slots_api.md",
      "item": [
        {
          "name": "GET /pages/:id/slots",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept-Language", "value": "{{acceptLanguage}}" }],
            "url": {
              "raw": "{{baseUrl}}/pages/{{pageId}}/slots?service_id={{serviceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["pages", "{{pageId}}", "slots"],
              "query": [{ "key": "service_id", "value": "{{serviceId}}" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('days', () => pm.expect(json.data.days).to.be.an('array'));",
                  "if (json.data.days.length) {",
                  "  pm.test('day shape', () => {",
                  "    const day = json.data.days[0];",
                  "    pm.expect(day.date).to.match(/^\\d{4}-\\d{2}-\\d{2}$/);",
                  "    pm.expect(day.slots).to.be.an('array');",
                  "    pm.expect(day.times).to.be.an('array');",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Page Services",
      "description": "CRUD услуг и категорий. Контракт: docs/pages_services_api.md",
      "item": [
        {
          "name": "GET /pages/:id/services",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept-Language", "value": "{{acceptLanguage}}" }],
            "url": "{{baseUrl}}/pages/{{pageId}}/services"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
